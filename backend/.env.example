# FitFlex Gym CRM - Environment Configuration

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=fitflex_jwt_secret_key_2024_change_in_production
JWT_EXPIRES_IN=7d

# WhatsApp Meta API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Meta Lead Ads Webhook
META_VERIFY_TOKEN=your_meta_verify_token
META_APP_SECRET=your_app_secret

# Firebase Cloud Messaging
FCM_PROJECT_ID=your_firebase_project_id
FCM_PRIVATE_KEY=your_firebase_private_key
FCM_CLIENT_EMAIL=your_firebase_client_email

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# SLA Settings (in minutes)
LEAD_RESPONSE_SLA=10

# Default Plans Pricing
DEFAULT_ANNUAL_PRICE=10000

