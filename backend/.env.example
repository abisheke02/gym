# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/gym_db

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Auth (REQUIRED in production) ─────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
ADMIN_PASSWORD=change_this_admin_password

# ── Razorpay (payment gateway) ────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── WhatsApp / Meta Cloud API ─────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=

# ── Email / SMTP (for password reset) ────────────────────
# Leave blank to use console.log in development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@ironmanfitness.com

# ── Firebase FCM (push notifications — optional) ─────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# ── Business settings ─────────────────────────────────────
LEAD_RESPONSE_SLA=10
DEFAULT_ANNUAL_PRICE=10000

# ── Frontend support contact (used in Help page) ──────────
VITE_SUPPORT_PHONE=+919876543210
VITE_SUPPORT_EMAIL=support@ironmanfitness.com
VITE_SUPPORT_WHATSAPP=919876543210
